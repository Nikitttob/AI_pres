# ═══════════════════════════════════════════════
# AI-мультиассистент — пример переменных окружения
# Скопируйте этот файл в .env и заполните значения
# ═══════════════════════════════════════════════

# ── Общее ──────────────────────────────────────
PORT=3000

# Основной LLM-провайдер: "claude" | "ollama" | "gigachat".
# Если основной недоступен — автоматический fallback на остальные.
LLM_PROVIDER=claude

# ── Claude API (Anthropic) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-sonnet-4-20250514

# ── Ollama (локальный LLM) ─────────────────────
# Хост Ollama-сервера. По умолчанию — локальный.
OLLAMA_HOST=http://127.0.0.1:11434
# Имя модели, которая будет использоваться для генерации.
# Установите её заранее: `ollama pull llama3`
OLLAMA_MODEL=llama3

# ── GigaChat (Sber) ────────────────────────────
# base64(CLIENT_ID:CLIENT_SECRET) из личного кабинета Сбера.
# Альтернативно — задайте раздельно GIGACHAT_CLIENT_ID и GIGACHAT_CLIENT_SECRET.
GIGACHAT_CREDENTIALS=
# Скоуп: GIGACHAT_API_PERS | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
# Если у вас не установлен Russian Trusted Root CA, временно можно задать "1"
# (НЕ рекомендуется в продакшене — отключает проверку TLS).
GIGACHAT_INSECURE_TLS=0

# ── Telegram Bot ───────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Rate limiting (запросов в минуту на IP) ────
# Общий лимит на все /api/* эндпоинты
RATE_LIMIT_API_PER_MIN=60
# Лимит на дорогие LLM/поиск запросы (/api/chat, /api/search)
RATE_LIMIT_CHAT_PER_MIN=15
# Лимит на админ-операции (/api/llm/primary)
RATE_LIMIT_ADMIN_PER_MIN=10
