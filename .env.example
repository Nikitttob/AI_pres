# ═══════════════════════════════════════════════
# AI-мультиассистент — пример переменных окружения
# Скопируйте этот файл в .env и заполните значения
# ═══════════════════════════════════════════════

# ── Общее ──────────────────────────────────────
PORT=3000

# Основной LLM-провайдер: "claude" или "ollama".
# Если основной недоступен — автоматический fallback на второй.
LLM_PROVIDER=claude

# ── Claude API (Anthropic) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-sonnet-4-20250514

# ── Ollama (локальный LLM) ─────────────────────
# Хост Ollama-сервера. По умолчанию — локальный.
OLLAMA_HOST=http://127.0.0.1:11434
# Имя модели, которая будет использоваться для генерации.
# Установите её заранее: `ollama pull llama3`
OLLAMA_MODEL=llama3

# ── Telegram Bot ───────────────────────────────
TELEGRAM_BOT_TOKEN=
